rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Each user can only read/write their own document.

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // ── Child Profiles ─────────────────────────────────────────────────────
      match /childProfiles/{profileId} {
        allow read, write: if isOwner(uid);

        // ── Watch Sessions ────────────────────────────────────────────────────
        match /watchSessions/{sessionId} {
          allow read, write: if isOwner(uid);
        }
      }
    }

    // ── Videos ───────────────────────────────────────────────────────────────
    // Any authenticated user can read the video catalog.
    // Only admins can write (create, update, delete) videos.

    match /videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
